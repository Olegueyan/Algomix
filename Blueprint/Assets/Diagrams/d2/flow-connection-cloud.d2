"Paramètres" -> "Saisir identifiants": "Se connecter / créer un compte"
"Saisir identifiants" -> "Valider connexion": "Email + mot de passe"
"Valider connexion" -> "Authentification valide ?"
"Authentification valide ?" -> "Saisir identifiants": "Non"
"Authentification valide ?" -> "Session cloud": "Oui"
"Session cloud" -> "Récupérer données": "Action récupérer"
"Session cloud" -> "Vider le cloud": "Action vider"
"Session cloud" -> "Changer mot de passe": "Action mot de passe"
"Récupérer données" -> "Backend cloud": "GET"
"Vider le cloud" -> "Backend cloud": "DELETE"
"Changer mot de passe" -> "Backend cloud": "PATCH"
"Backend cloud" -> "Retour utilisateur": "Résultat"
"Retour utilisateur" -> "Paramètres": "Fermer"

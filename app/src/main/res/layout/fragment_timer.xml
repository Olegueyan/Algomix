<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/timerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1EA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/timerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/timer_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="#E65100"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/chronoPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/timerDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/timer_zero"
                android:textAppearance="?attr/textAppearanceDisplayMedium"
                android:textColor="#1A1A1A"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startPauseButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:text="@string/timer_start" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resetButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="@string/timer_reset" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveTimeButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/timer_save_time" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/historyPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_elevated"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/historyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/timer_history_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="#000000"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/historyContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>

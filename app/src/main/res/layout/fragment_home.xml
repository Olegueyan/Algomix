<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1EA">

    <TextView
        android:id="@+id/cubeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:text="@string/cube_title"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="#1F3B73"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Visualisation du cube" />

    <TextView
        android:id="@+id/cubeSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:text="@string/cube_subtitle"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="#4D5B75"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cubeTitle"
        tools:text="Glisser pour orbiter, pinch zoom et reset" />

    <fr.olegueyan.algomix.ui.components.rubik.RubikCubeView
        android:id="@+id/cubeView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cubeSubtitle"
        app:rubikBackgroundColor="#FFF4F1EA"
        app:rubikBodyColor="#FF101114"
        app:rubikEnableDoubleTapReset="true"
        app:rubikInitialZoomFactor="1.0"
        app:rubikMaxZoomFactor="1.45"
        app:rubikMinZoomFactor="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1EA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="#E65100"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/modeToggleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/modeFreeButton"
                style="@style/Widget.Algomix.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_mode_free" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/modePlayButton"
                style="@style/Widget.Algomix.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_mode_play" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/modeEditButton"
                style="@style/Widget.Algomix.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_mode_edit" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:id="@+id/quickActionsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/scanButton"
                style="@style/Widget.Algomix.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/home_scan_cube" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/scrambleButton"
                style="@style/Widget.Algomix.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/home_scramble" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/playPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFFDF8F0"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loadAlgorithmButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="@string/home_load_algorithm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loadScrambleButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/home_load_scramble" />
            </LinearLayout>

            <TextView
                android:id="@+id/progressLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="#4D5B75"
                tools:text="Progression 2 / 10" />

            <ProgressBar
                android:id="@+id/playbackProgress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playPreviousButton"
                        style="@style/Widget.Algomix.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_previous" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playNextButton"
                        style="@style/Widget.Algomix.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/home_next" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playSpeedButton"
                        style="@style/Widget.Algomix.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        tools:text="x1.0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playAutoButton"
                        style="@style/Widget.Algomix.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/home_auto" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playLoopButton"
                        style="@style/Widget.Algomix.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/home_loop" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playResetButton"
                        style="@style/Widget.Algomix.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/home_reset" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/sequenceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F7FBFF"
                android:minHeight="40dp"
                android:padding="10dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="#003A5D"
                tools:text="R U R' U'" />

            <LinearLayout
                android:id="@+id/editActionsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editSaveButton"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/home_save"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editUndoButton"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/home_undo"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editRedoButton"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/home_redo"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editSuppressButton"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/home_suppress"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editDeleteAllButton"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/home_delete_all"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/cubeStage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:minHeight="@dimen/home_cube_stage_min_height">

            <fr.olegueyan.algomix.ui.components.rubik.RubikCubeView
                android:id="@+id/cubeView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:rubikBackgroundColor="#FFF4F1EA"
                app:rubikBodyColor="#FF101114"
                app:rubikEnableDoubleTapReset="true"
                app:rubikInitialZoomFactor="0.88"
                app:rubikMaxZoomFactor="1.45"
                app:rubikMinZoomFactor="0.88" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/lockRotationButton"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:contentDescription="@string/home_lock_rotation"
                app:icon="@drawable/ic_cube_lock"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetCubeButton"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="58dp"
                android:contentDescription="@string/home_reset_cube"
                app:icon="@drawable/ic_cube_reset"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/keyboardPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/keyboardCategoryToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/categoryCubeRotationsButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_category_cube_rotations" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/categoryFaceTurnsButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_category_face_turns" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/categorySliceMovesButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_category_slice_moves" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/categoryWideMovesButton"
                    style="@style/Widget.Algomix.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_category_wide_moves" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxHeight="200dp">

                <android.widget.GridLayout
                    android:id="@+id/moveGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="6"
                    android:useDefaultMargins="false" />
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
